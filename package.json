{
  "name": "epos-admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:generate": "tsx scripts/generate-api-tests.ts",
    "test:smoke": "vitest run --config vitest.smoke.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:report:serve": "vite preview --outDir test-reports/html --port 4173 --open",
    "test:report": "yarn test:generate && yarn test:smoke && yarn test:integration && yarn test:report:serve",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report test-reports/html/e2e",
    "test:all": "yarn test:report && yarn test:e2e"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@heroui/react": "^2.8.5",
    "@hookform/resolvers": "^5.2.2",
    "@reduxjs/toolkit": "^2.11.1",
    "@swc/helpers": "^0.5.23",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-query-devtools": "^5.91.1",
    "apexcharts": "^5.13.0",
    "axios": "^1.15.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.25",
    "libphonenumber-js": "^1.12.31",
    "moment": "^2.30.1",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-apexcharts": "^2.1.0",
    "react-date-range": "^2.0.1",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "react-icons": "^5.5.0",
    "react-phone-number-input": "^3.4.14",
    "react-redux": "^9.2.0",
    "recharts": "^3.8.1",
    "redux-persist": "^6.0.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-date-range": "^1.4.10",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.8",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "tailwindcss-debug-screens": "^3.0.1",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
